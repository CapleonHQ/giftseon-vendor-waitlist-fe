rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Waitlist entries — only Cloud Functions (admin SDK) can read/write
    // Frontend can only create via the Cloud Function, not directly
    match /vendorWaitlist/{doc} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // OTP codes — managed entirely by Cloud Functions (admin SDK)
    match /otpCodes/{email} {
      allow read, write: if false;
    }
  }
}
